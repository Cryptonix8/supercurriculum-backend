# ================================
# Supercurriculum Backend - Environment Variables
# ================================

# --------------------------------
# Database Configuration
# --------------------------------
DATABASE_URL="postgresql://username:password@localhost:5432/supercurriculum"

# --------------------------------
# Server Configuration
# --------------------------------
PORT=3000
NODE_ENV=development

# --------------------------------
# JWT Authentication
# --------------------------------
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRATION=7d

# --------------------------------
# Google OAuth (NEW)
# --------------------------------
# Get credentials from: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# --------------------------------
# AWS S3 File Upload (NEW)
# --------------------------------
# Set to true to enable S3 uploads
USE_S3=false

# AWS Credentials (get from AWS IAM)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_S3_BUCKET=supercurriculum-uploads

# --------------------------------
# OpenAI API (for AI Feedback & Chat)
# --------------------------------
OPENAI_API_KEY=sk-your-openai-api-key-here
YOUTUBE_API_KEY=your-youtube-api-key-here

# --------------------------------
# Rate Limiting (Optional)
# --------------------------------
THROTTLE_TTL=60000
THROTTLE_LIMIT=10

# --------------------------------
# Email Service (Optional - for password reset)
# --------------------------------
# Uncomment and configure when you add email service
# SENDGRID_API_KEY=your_sendgrid_api_key
# EMAIL_FROM=noreply@yourdomain.com
# EMAIL_FROM_NAME=Supercurriculum

# --------------------------------
# Docs folder (questionnaires & diagnostic tests PDFs)
# --------------------------------
# Base path relative to process.cwd() (backend folder when running from backend).
# Examples: "docs" (default), "../docs" (project root)
DOCS_BASE_PATH=docs

# Locale subfolders under DOCS_BASE_PATH. el-EN = flat PDFs (Diagnostic tests.pdf, General Questionnaires.pdf, year5–13.pdf). el-GR = DOCX + Didaktiko-Paketo-K* folders.
DOCS_EN_FOLDER=el-EN
DOCS_EL_FOLDER=el-GR

# --------------------------------
# CORS Configuration (Optional)
# --------------------------------
# CORS_ORIGIN=http://localhost:8081,http://localhost:3001
# CORS_CREDENTIALS=true

# --------------------------------
# Tutor simulation QA (not production chats)
# --------------------------------
# Optional: reuse an existing student user id instead of auto-creating tutor.simulation@internal.qa
# TUTOR_SIMULATION_USER_EMAIL=tutor.simulation@internal.qa
# Minimum pass rate for CLI exit 0 (0–1). Default 0.55
# TUTOR_SIM_MIN_PASS_RATE=0.55
# Alert if pass rate drops more than this vs previous run with same scenario set + tutor version
# TUTOR_SIM_REGRESSION_DELTA=0.1
# Label stored on runs (default qa)
# TUTOR_SIM_ENV=qa

# ================================
# Setup Instructions:
# ================================
# 1. Copy this file to .env
# 2. Update all values with your actual credentials
# 3. NEVER commit .env to git (already in .gitignore)
# 4. For production, use secure secret management
# ================================
