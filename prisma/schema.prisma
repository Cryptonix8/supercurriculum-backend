  studyStreak   Int       @default(0)
  lastStudyDate DateTime? @db.Date
  freezeUsedAt  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  xpEvents XpEvent[]

  @@map("user_gamification")
}

model XpEvent {
  id        String   @id @default(uuid())
  userId    String
  amount    Int
  reason    XpReason
  metadata  Json?
  createdAt DateTime @default(now())

  // Relations
  gamification UserGamification @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("xp_events")
}

model LearningChallenge {
  id          String         @id @default(uuid())
  title       String
  description String         @db.Text
  createdById String?
  subjectId   String?
  skillId     String?
  scope       ChallengeScope @default(PERSONAL)
  targetCount Int            @default(1)
  xpReward    Int            @default(30)
  startDate   DateTime?
  endDate     DateTime?
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  // Relations
  createdBy   User?                 @relation("ChallengeCreator", fields: [createdById], references: [id], onDelete: SetNull)
  subject     Subject?              @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  skill       Skill?                @relation(fields: [skillId], references: [id], onDelete: SetNull)
  assignments ChallengeAssignment[]

  @@index([createdById, isActive])
  @@index([scope, isActive])
  @@map("learning_challenges")
}

model ChallengeAssignment {
  id           String                    @id @default(uuid())
  challengeId  String
  studentId    String
  assignedById String?
  status       ChallengeAssignmentStatus @default(ASSIGNED)
  progress     Int                       @default(0)
  completedAt  DateTime?
  metadata     Json?
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt

  // Relations
  challenge   LearningChallenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  student     User              @relation("ChallengeStudent", fields: [studentId], references: [id], onDelete: Cascade)
  assignedBy  User?             @relation("ChallengeAssigner", fields: [assignedById], references: [id], onDelete: SetNull)

  @@unique([challengeId, studentId])
  @@index([studentId, status])
  @@index([assignedById, status])
  @@map("challenge_assignments")
}

// ============================================
// TEACHER CONTROLS & OVERRIDES
