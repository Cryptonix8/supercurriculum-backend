  reason       String?   @db.Text
  isActive     Boolean   @default(true)
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([studentId, isActive])
  @@map("teacher_overrides")
