// ============================================
// AI TUTOR - LEARNING SESSIONS
// ============================================

model LearningSession {
  id             String    @id @default(uuid())
  userId         String
  subjectId      String?
  duration       Int // minutes
  status         String    @default("active") // active, completed, interrupted
  sessionPlan    Json? // {reviewQuestions: [...], newConcepts: [...], mainExercises: [...], reflection: [...]}
  completedItems Json? // Array of completed item IDs
  adaptations    Json? // Log of difficulty adjustments made during session
  startedAt      DateTime  @default(now())
  completedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionItems     SessionItem[]
  interventionLogs InterventionLog[]

  @@index([userId, status])
  @@index([userId, startedAt])
  @@map("learning_sessions")
}

model SessionItem {
  id             String    @id @default(uuid())
  sessionId      String
  itemType       String // "review", "new_concept", "main_exercise", "reflection"
  skillId        String?
  question       String    @db.Text
  expectedAnswer String?   @db.Text
  difficulty     String // "easy", "medium", "hard", "extension"
  orderIndex     Int
  studentAnswer  String?   @db.Text
  isCorrect      Boolean?
  hintsGiven     Json? // Array of hints that were provided
  timeSpent      Int? // seconds
  attemptedAt    DateTime?
  createdAt      DateTime  @default(now())

  // Relations
  session LearningSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, orderIndex])
  @@map("session_items")
}

model InterventionLog {
  id               String    @id @default(uuid())
  sessionId        String
  skillId          String
  triggeredAt      DateTime  @default(now())
  reason           String    @db.Text // "Multiple errors in same skill"
  interventionType String // "micro_lesson", "guided_practice", "independent_practice"
  content          Json // The intervention content provided
  wasSuccessful    Boolean   @default(false)
  escalated        Boolean   @default(false)
  escalationNote   String?   @db.Text
  completedAt      DateTime?

  // Relations
  session LearningSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("intervention_logs")
}

