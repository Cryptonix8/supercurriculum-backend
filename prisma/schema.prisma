// ============================================
// PARENT VIEW SUMMARIES
// ============================================

model ParentSummary {
  id                String   @id @default(uuid())
  studentId         String
  weekStart         DateTime
  weekEnd           DateTime
  totalStudyMinutes Int      @default(0)
  sessionsCompleted Int      @default(0)
  subjectSummaries  Json // {maths: {status: "ON_TRACK", message: "..."}, english: {...}}
  recommendations   String[] // Array of friendly recommendations
  highlights        String[] // Positive achievements to share
  generatedAt       DateTime @default(now())

  @@unique([studentId, weekStart])
  @@index([studentId])
  @@map("parent_summaries")
}

// ============================================
// CURRICULUM & AI AGENT SYSTEM
// ============================================

model CurriculumTopic {
  id                    String   @id @default(uuid())
  yearGroupId           String
  subjectId             String
  topicName             String
  keyStage              KeyStage
  learningObjectives    Json // Array of learning objectives
  nationalCurriculumRef String? // Reference to national curriculum
  coreContent           String?  @db.Text
  extendedContent       String?  @db.Text
  keySkills             String[] // Array of key skills
  priorKnowledge        String[] // Array of prior knowledge requirements
  locale                String?  @default("en-GB") // "en-GB" or "el-GR"
  curriculumVersion     String? // "uk_v1", "gr_v1"
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  yearGroup                 YearGroup                 @relation(fields: [yearGroupId], references: [id], onDelete: Cascade)
  subject                   Subject                   @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  supercurriculumActivities SupercurriculumActivity[]

  @@index([yearGroupId, subjectId])
  @@index([keyStage])
  @@index([locale])
  @@map("curriculum_topics")
}

model SupercurriculumActivity {
  id                  String         @id @default(uuid())
  curriculumTopicId   String
  title               String
  description         String?        @db.Text
  instructions        String         @db.Text
  successCriteria     String?        @db.Text
  extensionLevel      ExtensionLevel
  curriculumAlignment Int // 0-100 score
  generatedBy         GeneratedBy
  teacherApproved     Boolean        @default(false)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  // Relations
  curriculumTopic CurriculumTopic @relation(fields: [curriculumTopicId], references: [id], onDelete: Cascade)

  @@index([curriculumTopicId])
  @@index([extensionLevel])
  @@index([generatedBy])
  @@index([teacherApproved])
  @@map("supercurriculum_activities")
}

model CurriculumStandard {
  id                 String   @id @default(uuid())
  standardCode       String   @unique // e.g., "NC-KS3-ENG-01"
  keyStage           KeyStage
  subjectId          String
  standardText       String   @db.Text // Official NC wording
  assessmentCriteria Json // JSON structure for assessment criteria
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Relations
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@index([keyStage, subjectId])
  @@index([standardCode])
  @@map("curriculum_standards")
}

